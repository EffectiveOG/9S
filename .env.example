# ---------------------------------------------------------------------------
# Jarvis environment configuration
# Copy this file to `.env` and adjust the values for your machine:
#     cp .env.example .env
# `.env` is git-ignored and should never be committed.
# ---------------------------------------------------------------------------

# General
DEBUG=True
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# Paths (relative to the project root)
DATA_DIR=data
MODELS_DIR=data/models
KNOWN_FACES_DIR=data/known_faces
LOGS_DIR=data/logs

# Vision
CAMERA_INDEX=0                       # OpenCV camera index (0 = default webcam)
FRAME_WIDTH=1280
FRAME_HEIGHT=720
FPS=30

# Audio
AUDIO_DEVICE_INDEX=0                 # legacy; see INPUT/OUTPUT below
AUDIO_INPUT_DEVICE_INDEX=            # leave blank to use the system default mic
AUDIO_OUTPUT_DEVICE_INDEX=           # leave blank to use the system default speakers
SAMPLE_RATE=16000
CHUNK_SIZE=1024

# Database
DATABASE_URL=sqlite:///data/jarvis.db

# ---------------------------------------------------------------------------
# Web / authentication  (read by jarvis/web/security.py)
# ---------------------------------------------------------------------------
# Signing key for JWT access tokens. If unset, a random key is generated and
# persisted to config/.secret_key. Set an explicit value in production.
JARVIS_SECRET_KEY=

# Initial dashboard login. If JARVIS_ADMIN_PASSWORD is unset, a default
# admin/admin account is seeded (with a warning) — DO NOT ship that.
JARVIS_ADMIN_USER=admin
JARVIS_ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Device secrets  (referenced as ${VAR} inside config/jarvis_config.json)
# Keep the real values here, never in the committed JSON config.
# ---------------------------------------------------------------------------
HUE_API_KEY=
HUE_BACKUP_API_KEY=
PSN_ID=
PSN_ACCESS_TOKEN=
PSN_REFRESH_TOKEN=
XBOX_LIVE_TOKEN=
XBOX_REFRESH_TOKEN=
